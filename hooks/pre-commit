#!/usr/bin/env bash
# pre-commit: run lint on staged .go files. Fail commit on any finding.
# Canonical lives in agoodkind/go-makefile; consumer repos symlink to it.
# Honors `git commit --no-verify` per git convention (no extra blocking).

set -eu

# Find staged Go files (Added, Copied, Modified). Skip if none.
staged=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null | grep -E '\.go$' || true)
[ -z "$staged" ] && exit 0

# Group staged files by the directory of their nearest ancestor Makefile.
# Works for both single-Makefile-at-root layouts (clyde, agent-gate, etc.)
# and subdir layouts (dots/, mwan/go/) where the git root has no Makefile.
git_root=$(git rev-parse --show-toplevel)

find_makefile_dir() {
    local f="$1"
    local d
    d=$(dirname "$git_root/$f")
    while [ "$d" != "/" ] && [ "$d" != "$git_root/.." ]; do
        if [ -f "$d/Makefile" ] && grep -qE '^(include|-include) bootstrap\.mk$' "$d/Makefile" 2>/dev/null; then
            printf '%s\n' "$d"
            return 0
        fi
        d=$(dirname "$d")
    done
    return 1
}

declare -A by_dir
while IFS= read -r f; do
    [ -n "$f" ] || continue
    if mk_dir=$(find_makefile_dir "$f"); then
        # Convert f (relative to git_root) into a path relative to mk_dir.
        # Pure shell, no python dep.
        mk_dir_rel="${mk_dir#$git_root/}"
        if [ "$mk_dir_rel" = "$mk_dir" ]; then
            rel_path="$f"
        else
            rel_path="${f#$mk_dir_rel/}"
        fi
        by_dir[$mk_dir]+="$rel_path "
    fi
done <<< "$staged"

# Run both gates the build pipeline runs:
#   - lint-diff: agent-callable target that lints staged .go files via
#     golangci-lint (typecheck gets package siblings, output filtered to
#     staged files, baseline-gated by default).
#   - staticcheck-extra: catches custom analyzers (no_any, slog/boundary
#     hygiene, thin_wrapper, etc.) that golangci-lint doesn't run.
status=0
for mk_dir in "${!by_dir[@]}"; do
    files="${by_dir[$mk_dir]}"
    pkgs=$(printf '%s\n' $files | xargs -n1 dirname 2>/dev/null | sort -u | awk '{print "./" $0}' | tr '\n' ' ')
    (cd "$mk_dir" && make lint-diff >&2) || status=$?
    (cd "$mk_dir" && make staticcheck-extra STATICCHECK_EXTRA_TARGETS="$pkgs" >&2) || status=$?
done
exit "$status"
