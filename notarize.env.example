# Copy to notarize.env and fill in your 1Password op:// paths.
# notarize.env is gitignored. Never commit it.
#
# Local release: make release
# CI: store each resolved value as a GitHub Secret with the same name.

APPLE_DEVELOPER_ID_CERT=op://Private/ITEM/FIELD
APPLE_DEVELOPER_ID_CERT_PASSWORD=op://Private/ITEM/FIELD
APPLE_NOTARYTOOL_ISSUER_ID=op://Private/ITEM/FIELD
APPLE_NOTARYTOOL_KEY_ID=op://Private/ITEM/FIELD
APPLE_NOTARYTOOL_KEY=op://Private/ITEM/AuthKey_XXXX.p8
