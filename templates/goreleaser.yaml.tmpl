version: 2

project_name: [[.Binary]]

builds:
  - id: [[.Binary]]
    main: ./cmd/[[.Binary]]
    binary: [[.Binary]]
    env:
      - CGO_ENABLED=0
    goos:
      - darwin
      - linux
    goarch:
      - amd64
      - arm64
    ldflags:
      - -s -w

archives:
  - id: [[.Binary]]
    formats: [tar.gz]
    name_template: "{{ .ProjectName }}_{{ .Os }}_{{ .Arch }}"
    files:
      - README.md

checksum:
  name_template: checksums.txt
  algorithm: sha256

notarize:
  macos:
    - enabled: '{{ isEnvSet "APPLE_DEVELOPER_ID_CERT" }}'
      ids:
        - [[.Binary]]
      sign:
        certificate: "{{ .Env.APPLE_DEVELOPER_ID_CERT }}"
        password: "{{ .Env.APPLE_DEVELOPER_ID_CERT_PASSWORD }}"
      notarize:
        issuer_id: "{{ .Env.APPLE_NOTARYTOOL_ISSUER_ID }}"
        key_id: "{{ .Env.APPLE_NOTARYTOOL_KEY_ID }}"
        key: "{{ .Env.APPLE_NOTARYTOOL_KEY }}"
        wait: true
        timeout: 20m

release:
  name_template: "{{ .Date }} · build {{ .Env.HEX_RUN }} · {{ .ShortCommit }}"

changelog:
  sort: asc
  filters:
    exclude:
      - "^docs:"
      - "^chore:"
      - Merge pull request
      - Merge branch
